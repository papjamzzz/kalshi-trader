# ── Kalshi ────────────────────────────────────────────────────────────────────
# Same key as KK — make sure trading/order permissions are ENABLED in Kalshi settings
KALSHI_API_KEY=your-kalshi-api-key-here

# ── Twilio SMS ────────────────────────────────────────────────────────────────
# Sign up at twilio.com → get a phone number → grab these from the console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Gmail Email ───────────────────────────────────────────────────────────────
# From: jeremiahstepehensmith@gmail.com → To: underwaterfile@proton.me
# You need a Gmail App Password (NOT your regular password):
#   myaccount.google.com → Security → 2-Step Verification → App passwords
#   Select "Mail" + "Mac" → copy the 16-char password below
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Cross-Market Edge (The Odds API) ─────────────────────────────────────────
# Free tier: 500 requests/month. Sign up at https://the-odds-api.com
# Covers DraftKings, FanDuel, BetMGM, Caesars, PointsBet + 70 others
# Leave blank to skip sportsbook enrichment (Polymarket still runs, it's free)
ODDS_API_KEY=your-odds-api-key-here
